# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Compiled binaries ---
*.com
*.class
*.dll
*.exe
*.exes
*.o
*.so

# --- Archives (use DVC for datasets, never commit raw archives) ---
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# --- Data: tracked via DVC, not Git ---
data/raw/
data/processed/
data/synthetic/
data/dataset/

# --- Outputs (training/eval artifacts) ---
outputs/
mlruns/
checkpoints/

# --- Logs and databases ---
*.log
*.sql
*.sqlite
logs/

# --- Secrets ---
configs/credentials.json
.env
.env.*
!.env.example

# --- Test/coverage artifacts ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.ruff_cache/
.mypy_cache/
.cache/

# --- Notebooks scratch ---
.ipynb_checkpoints/

# --- Claude Code local settings ---
.claude/

# --- Pesquisa bibliográfica ---
# PDFs open access (arXiv, NIST, NeurIPS, etc.) são versionados para
# rastreabilidade acadêmica. Apenas arquivos de texto extraído ficam
# ignorados (são derivados dos PDFs via pypdf, podem ser regenerados).
docs/ativo/04_pesquisa_bibliografica/pdfs/*.txt

# --- Microsoft Office lock files ---
# Arquivos temporários criados pelo Office (Word, PowerPoint, Excel)
# enquanto o arquivo está aberto. Não devem ser versionados.
~$*
